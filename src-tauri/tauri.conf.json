{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumo",
  "version": "0.1.3",
  "identifier": "com.hao.lumo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lumo Player",
        "width": 1500,
        "height": 850,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/lumo_log.ico"
    ]
  }
}
